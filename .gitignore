# ==========================================
# 1. Python 核心與安裝產生物 (必備)
# ==========================================
__pycache__/
*.py[cod]
*$py.class

# 套件中繼資料 (例如你看到的 .egg-info)
*.egg-info/
.installed.cfg
build/
dist/
wheels/
sdist/

# ==========================================
# 2. 虛擬環境 (Virtual Environments)
# ==========================================
.venv/
venv/
env/
ENV/
bin/
lib/
include/

# ==========================================
# 3. 實驗數據與資料庫 (QCoDeS 專用)
# ==========================================
# 避免將龐大的實驗數據庫上傳，每台電腦應保持本地資料
*.db
*.db-journal
# 如果你有存放暫存數據的資料夾
data/
logs/

# ==========================================
# 4. 作業系統特定檔案 (跨平台開發必備)
# ==========================================
# Windows
Thumbs.db
desktop.ini
$RECYCLE.BIN/

# macOS
.DS_Store
.AppleDouble
.LSOverride
._*
.Spotlight-V100
.Trashes

# ==========================================
# 5. IDE 與 編輯器設定 (VS Code / PyCharm / Jupyter)
# ==========================================
.vscode/
.idea/
*.swp
*.swo

# Jupyter Notebook 暫存
.ipynb_checkpoints
*/.ipynb_checkpoints/*

# ==========================================
# 6. 敏感資訊與環境變數
# ==========================================
.env
.secrets
# 儀器地址、密碼等私密設定

experiments/*
!experiments/templates
